# build output — too big for git, ships as a GitHub Release instead
out/
*.iso

# local pacman repo (rebuilt by repo/build-repo.sh)
repo/x86_64/

# built packages
pkg/**/*.pkg.tar.*
pkg/**/src/
pkg/**/pkg/
# vendored upstream source tarballs (makepkg re-fetches them)
pkg/**/*.tar.gz

# the staged payload (rices, themes, tooling) — tracked so anyone can build the
# ISO from a fresh clone. ~164MB. Re-stage from a running system with the staging
# step if you change configs.
# pkg/bite-os/payload/

# archiso build dirs — regenerated by build-iso.sh, and often root-owned
.build-work/
.build-profile/
/airootfs/
