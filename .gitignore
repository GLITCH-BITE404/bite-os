# build output — too big for git, ships as a GitHub Release instead
out/
*.iso

# local pacman repo (rebuilt by repo/build-repo.sh)
repo/x86_64/

# built packages
pkg/**/*.pkg.tar.*
pkg/**/src/
pkg/**/pkg/
# vendored upstream source tarballs (makepkg re-fetches them)
pkg/**/*.tar.gz

# the staged payload is large (rices, themes); rebuilt from the system.
# Comment the next line out if you want the payload tracked in git.
pkg/bite-os/payload/

# archiso build dirs — regenerated by build-iso.sh, and often root-owned
.build-work/
.build-profile/
/airootfs/
