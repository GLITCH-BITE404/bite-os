#!/usr/bin/env bash
# ━━━ BITE-OS — live-session Hyprland launcher ━━━
# SDDM autologin (Session=bite-os-hyprland) calls THIS.
#
# Hard-won lessons baked into this file:
#  * On the live ISO /home/bite gets wiped by the boot overlay, so ANYTHING we
#    copy into it at build/login time can vanish → Hyprland falls back to its
#    autogenerated config and the installer never starts.
#  * The full caelestia/quickshell rice + the bite-os-healthcheck self-repair
#    service crash/relaunch in the live VM and hijack the session.
#
# So on the LIVE ISO we DO NOT touch /home/bite. We launch Hyprland straight
# from a READ-ONLY system config (/usr/share/bite-os/live/hyprland.conf) via
# `-c`, which the overlay can't wipe, and we defensively kill the rice's
# self-repair + shell so caelestia can't take over. The real rice still ships
# untouched on the INSTALLED system via the bite-os package's /etc/skel.
set -u
LOG=/tmp/bite-os-session.log
LIVE_CFG=/usr/share/bite-os/live/hyprland.conf

is_live() { [ -d /run/archiso ] || grep -q archisobasedir /proc/cmdline 2>/dev/null; }

{
    echo "════════ $(date -Is) bite-os-hyprland-session ════════"
    echo "uid=$(id -u) home=$HOME live=$(is_live && echo yes || echo no)"
} >> "$LOG" 2>&1

if is_live && [ -f "$LIVE_CFG" ]; then
    {
        echo "stage: LIVE → launching Hyprland with read-only config $LIVE_CFG"
        # Make sure the rice's self-repair service can't relaunch caelestia in
        # the live session. Best-effort; ignore if the user bus isn't up yet.
        systemctl --user mask bite-os-healthcheck.service >/dev/null 2>&1 || true
        pkill -u "$(id -u)" -x quickshell  >/dev/null 2>&1 || true
        pkill -u "$(id -u)" -f caelestia   >/dev/null 2>&1 || true
    } >> "$LOG" 2>&1
    exec /usr/bin/Hyprland -c "$LIVE_CFG" "$@"
fi

# Installed system (or live config missing): behave like a normal OS — let
# Hyprland read the user's own ~/.config/hypr (the full rice from /etc/skel).
echo "stage: not live (or no live cfg) → normal Hyprland" >> "$LOG" 2>&1
exec /usr/bin/Hyprland "$@"
